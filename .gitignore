# Cursor / agent debug session logs (NDJSON mirrors from CosmeticDebugLog / Cursor Debug panel).
# Canonical mvm logs live in %APPDATA%\HLAE\debuglogs\ — never commit copies here.
/debug-*.log
/.cursor/debug-*.log
/.cursor/*.log
mvm_debug_*.log

# Accidental root-level artifacts seen before: some tool run from the repo cwd instead of
# the real Windows profile writes here, and raw netcon/console output has landed as files
# named after the command itself (`demo_pause`, `mirv_filmmaker follow status`, etc.).
# Build/launch/install scripts also redirect stdout to *.log here when run from repo root.
/*.log
/AppData/
/demo_pause
/mirv_filmmaker*
